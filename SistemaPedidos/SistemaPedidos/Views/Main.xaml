<Window x:Class="SistemaPedidos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Pedidos"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F6FA"
        Closed="MainClosed"
        MinHeight="700" 
        MinWidth="1280">
    <Window.Resources>

        <Style x:Key="Title" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="0,10,0,50"/>
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="TextButtonSidebar" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style TargetType="Image">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20" />
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Background="#212529" Grid.Column="0">
            <TextBlock Style="{StaticResource Title}" Text="SISTEMA DE PEDIDOS"/>
            
            <Button Click="Home_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/img/house.png" />
                    <TextBlock Style="{StaticResource TextButtonSidebar}" Text="Home"/>
                </StackPanel>
            </Button>

            <Button Click="Pessoa_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/img/user.png"/>
                    <TextBlock Style="{StaticResource TextButtonSidebar}" Text="Pessoa"/>
                </StackPanel>
            </Button>

            <Button Click="Produto_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/img/product.png"/>
                    <TextBlock Style="{StaticResource TextButtonSidebar}" Text="Produto"/>
                </StackPanel>
            </Button>


            <Button Click="Pedido_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/img/order.png"/>
                    <TextBlock Style="{StaticResource TextButtonSidebar}" Text="Pedido"/>
                </StackPanel>
            </Button>

            <Button Click="Sair_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/img/exit.png"/>
                    <TextBlock Style="{StaticResource TextButtonSidebar}" Text="Sair"/>  
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Conteúdo principal -->
        <Grid Grid.Column="1" Background="White">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
        </Grid>
    </Grid>
</Window>