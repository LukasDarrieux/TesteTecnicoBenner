<Window x:Class="SistemaPedidos.Views.Pages.frmPedidoStatus"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SistemaPedidos.Views.Pages"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="frmPedidoStatus" MinHeight="250" Height="250" MaxHeight="250" MinWidth="800" MaxWidth="800" Width="800" WindowStyle="None">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,0,0,10">
            <TextBlock Text="Atualizar status pedido" FontSize="20" FontWeight="SemiBold"/>
        </Grid>

        <Grid Grid.Row="1" Margin="10,0,0,10">
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,10,0" Grid.Column="0">
                    <TextBlock Text="Pessoa"/>
                    <TextBox x:Name="txtPessoa" Height="30" IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0" Grid.Column="1">
                    <TextBlock Text="Data"/>
                    <TextBox x:Name="txtData" Height="30" IsReadOnly="True"/>
                </StackPanel>

            </Grid>
        </Grid>
        
        <Grid Grid.Row="2" Margin="10,0,0,10">
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,10,0" Grid.Column="0">
                    <TextBlock Text="Pagamento"/>
                    <TextBox x:Name="txtPagamento" Height="30" IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0" Grid.Column="1">
                    <TextBlock Text="Valor Total"/>
                    <TextBox x:Name="txtValorTotal" Height="30" IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0" Grid.Column="2">
                    <TextBlock Text="Status"/>
                    <ComboBox x:Name="cbStatus" Height="30" SelectedIndex="-1" Text="Selecione..."/>
                </StackPanel>

            </Grid>

        </Grid>

        <Grid Grid.Row="3" >
            <Grid HorizontalAlignment="Right" Margin="0,10,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="10,10,0,0" Style="{StaticResource DangerButton}" Click="btnCancelar_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/img/x.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Cancelar"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Margin="10,10,0,0" Style="{StaticResource SuccessButton}" Click="btnSalvar_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/img/save.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Salvar"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

    </Grid>
</Window>
