<Window x:Class="SistemaPedidos.Views.Pages.frmPedidoItem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SistemaPedidos.Views.Pages"
        mc:Ignorable="d"
        Title="PedidoItem" MaxHeight="200" MinHeight="200" MaxWidth="800" MinWidth="800"
        WindowStartupLocation="CenterScreen" WindowStyle="None">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,0,0,10">
            <TextBlock Text="Itens do Pedido" FontSize="20" FontWeight="SemiBold"/>
        </Grid>

        <Grid Grid.Row="1" Margin="10,0,0,10">
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Margin="0,0,10,0" Grid.Column="0">
                    <TextBlock Text="Produto"/>
                    <ComboBox x:Name="cbProdutos" Height="30" SelectedIndex="-1" Text="Selecione..." SelectionChanged="cbProdutos_Selected"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0" Grid.Column="1">
                    <TextBlock Text="Quantidade"/>
                    <TextBox x:Name="txtQuantidade" Height="30" PreviewTextInput="txtQuantidade_PreviewTextInput" LostFocus="txtQuantidade_LostFocus"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0" Grid.Column="2">
                    <TextBlock Text="Preço"/>
                    <TextBox x:Name="txtPrecoUnitario" Height="30" IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Margin="0,0,10,0" Grid.Column="3">
                    <TextBlock Text="Valor total"/>
                    <TextBox x:Name="txtValorTotal" Height="30" IsReadOnly="True"/>
                </StackPanel>
            </Grid>
            
        </Grid>

        <Grid Grid.Row="2" >
            <Grid HorizontalAlignment="Right" Margin="0,10,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="10,10,0,0" Style="{StaticResource DangerButton}" Click="btnCancelar_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/img/x.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Cancelar"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Margin="10,10,0,0" Style="{StaticResource SuccessButton}" Click="btnAdicionar_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/img/plus.png" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Adicionar"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

    </Grid>
</Window>
