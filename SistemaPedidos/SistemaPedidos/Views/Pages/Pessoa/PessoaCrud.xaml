<Page x:Class="SistemaPedidos.Views.Pages.PessoaCrud"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SistemaPedidos.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="Pessoa"
      Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Cadastro de Pessoa"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,15"
               x:Name="lblTitulo"/>

        <!-- Conteúdo -->
        <StackPanel Grid.Row="1">

            <!-- Nome + CPF -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label Content="Nome"/>
                    <TextBox x:Name="txtNome"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Label Content="CPF"/>
                    <TextBox x:Name="txtCpf" PreviewTextInput="txtCpf_PreviewTextInput" MaxLength="11" />
                </StackPanel>
            </Grid>

            <!-- Endereço -->
            <Border Background="White" BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                <StackPanel>

                    <TextBlock Text="Endereço"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,10"/>

                    <!-- Rua + Número -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Label Content="Rua"/>
                            <TextBox x:Name="txtRua"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <Label Content="Número"/>
                            <TextBox x:Name="txtNumero"/>
                        </StackPanel>
                    </Grid>

                    <!-- Bairro + CEP -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Label Content="Bairro"/>
                            <TextBox x:Name="txtBairro"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <Label Content="CEP"/>
                            <TextBox x:Name="txtCep" PreviewTextInput="txtCep_PreviewTextInput" MaxLength="8"/>
                        </StackPanel>
                    </Grid>

                    <!-- Cidade + Estado -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <Label Content="Cidade"/>
                            <TextBox x:Name="txtCidade"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <Label Content="Estado"/>
                            <TextBox x:Name="txtEstado"/>
                        </StackPanel>
                    </Grid>

                    <!-- Complemento -->
                    <Label Content="Complemento"/>
                    <TextBox x:Name="txtComplemento" Height="60" AcceptsReturn="True"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Botões -->
        <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,20,0,0">

            <Button x:Name="btnCancelar"
                Content="Cancelar"
                Style="{StaticResource SecondaryButton}"
                Margin="0,0,10,0"
                Click="btnCancelar_Click"/>

            <Button 
                x:Name="btnSalvar"
                Content="Salvar"
                Style="{StaticResource PrimaryButton}"
                Click="btnSalvar_Click"/>
        </StackPanel>
    </Grid>
</Page>
