<Page x:Class="SistemaPedidos.Views.Pages.ProdutoList"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SistemaPedidos.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProdutoList"
      Background="White">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🔹 TÍTULO -->
        <TextBlock Grid.Row="0" Text="Cadastro de Produtos"
               FontSize="22"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

        <Grid Grid.Row="1" HorizontalAlignment="Left">
            <Button Margin="2" Style="{StaticResource SuccessButton}" Click="btnCadastrar_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/img/plus.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Cadastrar"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 🔹 FILTROS -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Nome -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Nome"/>
                <TextBox x:Name="txtNome" />
            </StackPanel>

            <!-- Codigo -->
            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                <TextBlock Text="Código"/>
                <TextBox x:Name="txtCodigo" />
            </StackPanel>

            <!-- Valor -->
            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                <TextBlock Text="Valor"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtValorInicial" Grid.Column="0" PreviewTextInput="txtValor_PreviewTextInput"/>
                    <TextBox x:Name="txtValorFinal" Grid.Column="2" PreviewTextInput="txtValor_PreviewTextInput"/>
                </Grid>
            </StackPanel>

            <!-- Botão Pesquisar -->
            <Button Grid.Column="3" Margin="0,10,0,0" Style="{StaticResource PrimaryButton}" Click="btnPesquisar_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/img/search.png" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="Pesquisar"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 🔹 DATA GRID -->
        <DataGrid Grid.Row="3"
              ItemsSource="{Binding Produto}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              IsReadOnly="True"
              x:Name="dataGridProdutos">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="2*"/>
                <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="*"/>
                <DataGridTextColumn Header="Valor" Binding="{Binding Valor}" Width="*"/>

                <!-- Ações -->
                <DataGridTemplateColumn Header="Ações" Width="260">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>

                            <StackPanel Orientation="Horizontal">

                                <Button Margin="2" Style="{StaticResource PrimaryButton}" Click="btnEditar_Click" Width="80">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Resources/img/pencil.png" Width="16" Height="16" Margin="0,0,5,0"/>
                                        <TextBlock Text="Editar"/>
                                    </StackPanel>
                                </Button>

                                <Button Margin="2" Style="{StaticResource DangerButton}" Click="btnExcluir_Click" Width="80">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Resources/img/trash.png" Width="16" Height="16" Margin="0,0,5,0"/>
                                        <TextBlock Text="Excluir"/>
                                    </StackPanel>
                                </Button>

                                <Button Margin="2" Style="{StaticResource SuccessButton}" Click="btnVisualizar_Click" Width="80">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Resources/img/eye.png" Width="16" Height="16" Margin="0,0,5,0"/>
                                        <TextBlock Text="Exibir"/>
                                    </StackPanel>
                                </Button>

                            </StackPanel>

                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

        <!-- 🔹 TOTAL REGISTROS -->
        <TextBlock Grid.Row="4"
               FontWeight="SemiBold"
               Margin="0,10,0,0"
               x:Name="lblQuantidade"/>
    </Grid>
</Page>
