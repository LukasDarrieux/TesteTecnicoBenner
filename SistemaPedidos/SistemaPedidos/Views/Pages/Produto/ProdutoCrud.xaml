<Page x:Class="SistemaPedidos.Views.Pages.ProdutoCrud"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SistemaPedidos.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProdutoCrud"
      Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Cadastro de Produto"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,15"
               x:Name="lblTitulo"/>

        <!-- Conteúdo -->
        <StackPanel Grid.Row="1">

            <StackPanel Grid.Column="0">
                <Label Content="Nome"/>
                <TextBox x:Name="txtNome"/>
            </StackPanel>
            
        </StackPanel>

        <StackPanel Grid.Row="2">

            <!-- Codigo + Valor -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Label Content="Código"/>
                    <TextBox x:Name="txtCodigo"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Label Content="Valor"/>
                    <TextBox x:Name="txtValor" PreviewTextInput="txtValor_PreviewTextInput"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Botões -->
        <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,20,0,0">

            <Button x:Name="btnCancelar"
                Content="Cancelar"
                Style="{StaticResource SecondaryButton}"
                Margin="0,0,10,0"
                Click="btnCancelar_Click"/>

            <Button 
                x:Name="btnSalvar"
                Content="Salvar"
                Style="{StaticResource PrimaryButton}"
                Click="btnSalvar_Click"/>
        </StackPanel>
    </Grid>
</Page>
